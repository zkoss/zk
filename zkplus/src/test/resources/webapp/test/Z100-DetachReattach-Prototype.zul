<?xml version="1.0" encoding="UTF-8"?>
<?variable-resolver class="org.zkoss.zkplus.spring.DelegatingVariableResolver"?>
<window id="win" xmlns="http://www.zkoss.org/2005/zul">
    <zscript>
        void doDetachReattach() {
            org.zkoss.zk.ui.Component comp = win.getFellow("comp");
            org.zkoss.zk.ui.Component host = comp.getParent();
            comp.detach();
            host.appendChild(comp);
        }
    </zscript>
    <div id="host">
        <div id="comp" apply="${composerScopePrototype}">
            <label id="hashLabel"/>
        </div>
    </div>
    <button id="detachReattachBtn" label="DetachReattach" onClick="doDetachReattach()"/>
</window>
