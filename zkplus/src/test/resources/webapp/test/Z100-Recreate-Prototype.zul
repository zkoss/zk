<?xml version="1.0" encoding="UTF-8"?>
<?variable-resolver class="org.zkoss.zkplus.spring.DelegatingVariableResolver"?>
<window id="win" xmlns="http://www.zkoss.org/2005/zul">
    <zscript>
        void doRecreate() {
            org.zkoss.zk.ui.Component c = win.getFellow("container");
            c.getChildren().clear();
            org.zkoss.zk.ui.Executions.createComponents("/test/inner-prototype.zul", c, null);
        }
    </zscript>
    <div id="container">
        <div id="comp" apply="${composerScopePrototype}">
            <textbox id="textbox"/>
            <label id="hashLabel"/>
        </div>
    </div>
    <button id="recreateBtn" label="Recreate" onClick="doRecreate()"/>
</window>
