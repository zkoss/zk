<zk>
	<grid id="grid">
		<columns>
			<column label="Item" />
			<column label="Price" />
		</columns>
		<rows id="rows">
			<group id="g1" label="Fruit" />
			<row>
				<label value="Apple" />
				<label value="$1.00" />
			</row>
			<row>
				<label value="Banana" />
				<label value="$0.50" />
			</row>
			<groupfoot id="gf1">
				<cell colspan="2">
					<label id="footLabel" value="Fruit subtotal: $1.50" />
				</cell>
			</groupfoot>
		</rows>
	</grid>
</zk>
