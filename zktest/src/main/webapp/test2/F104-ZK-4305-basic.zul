<zk>
	<vlayout spacing="10px" hflex="1">
		<label value="ZK-4305 basic — Daterangebox renders two inputs and a calendar button"/>
		<daterangebox id="dr" format="yyyy-MM-dd"/>
		<hlayout>
			<button label="Read range" onClick='Clients.evalJavaScript("var w = zk.Widget.$(\"$dr\");" +
				"alert(JSON.stringify({begin: w._beginValue, end: w._endValue}));")'/>
		</hlayout>
	</vlayout>
</zk>
