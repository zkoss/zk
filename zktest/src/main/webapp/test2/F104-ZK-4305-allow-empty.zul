<zk>
	<vlayout spacing="10px" hflex="1">
		<label value="ZK-4305 allow-empty — open-ended ranges"/>
		<hlayout>
			<label value="none:"/>
			<daterangebox id="drNone" allowEmpty="none"/>
		</hlayout>
		<hlayout>
			<label value="begin:"/>
			<daterangebox id="drBegin" allowEmpty="begin"/>
		</hlayout>
		<hlayout>
			<label value="end:"/>
			<daterangebox id="drEnd" allowEmpty="end"/>
		</hlayout>
		<hlayout>
			<label value="both:"/>
			<daterangebox id="drBoth" allowEmpty="both"/>
		</hlayout>
	</vlayout>
</zk>
