<zk>
	<vlayout spacing="10px" hflex="1">
		<label value="ZK-4305 onError — unparseable input delivers a typed ErrorEvent"/>
		<daterangebox id="dr" format="yyyy-MM-dd"
			onError='cap.setValue("type=" + event.getClass().getSimpleName()
				+ ";msg=" + event.getMessage() + ";val=" + event.getValue())'/>
		<label id="cap"/>
	</vlayout>
</zk>
