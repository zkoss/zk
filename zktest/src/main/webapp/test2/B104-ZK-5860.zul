<?xml version="1.0" encoding="UTF-8"?>
<!--
B104-ZK-5860.zul

	Purpose:
		Verify the time wheel remains usable after Datebox.setConstraint() in tablet UI.

	History:
		Tue Feb 10 11:58:25 CST 2026, Created by peakerlee

Copyright (C) 2026 Potix Corporation. All Rights Reserved.
-->
<zk>
	<div>
		simplest
		<datebox id="dbox1" format="dd-MMM-yyyy HH:mm" width="230px" readonly="true"
				constraint="between 20241224 and 20241226"/>
		<button id="btn1" label="Change Date"
				onClick='dbox1.setConstraint("between 20241224 and 20241228")'/>
	</div>
	<div viewModel="@id('vm')@init('org.zkoss.zktest.test2.B104_ZK_5860VM')">
		real use case
		<datebox id="dbox2" value="@bind(vm.selectedDate)" format="dd-MMM-yyyy HH:mm"
				width="230px" readonly="true"
				constraint="@load(vm.selectedDateConstraint)"/>
		<button id="btn2" label="Change Date" onClick="@command('changeDate')"/>
	</div>
</zk>
