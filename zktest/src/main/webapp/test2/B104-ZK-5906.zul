<zk>
	<!-- The exact scenario from ZK-5906: a real external href together with
	        a server-side onClick listener. -->
	<a id="lnk" href="https://www.zkoss.org" onClick='Clients.log("foo")'>click me</a>
	<!-- A new-tab link: clicking it must NOT suppress the desktop teardown,
	        because the current page keeps living. -->
	<a id="lnkBlank" href="https://www.zkoss.org" target="_blank" onClick='Clients.log("bar")'>open in new tab</a>
</zk>
