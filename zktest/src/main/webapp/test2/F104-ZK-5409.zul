    <style>
        .menu-wrap {
            max-width: 760px;
            margin: 20px auto;
            padding: 20px;
            border: 1px solid #d7dce3;
            border-radius: 10px;
            background: #f9fbfd;
            box-shadow: 0 4px 12px rgba(15, 23, 42, 0.08);
