        .menu-title {
            font-size: 20px;
            font-weight: 700;
            margin: 0 0 6px 0;
            color: #1f2937;
        }

        .menu-subtitle {
            margin: 0 0 14px 0;
            color: #4b5563;
            font-size: 13px;
        }

        .menu-list {
            margin: 0;
            padding: 0;
            list-style: none;
            display: grid;
            gap: 8px;
        }

        .menu-link {
            display: block;
            text-decoration: none;
            border: 1px solid #d9e2ec;
            border-radius: 8px;
            padding: 8px 10px;
            color: #0f4c81;
            background: #ffffff;
            transition: background-color .12s ease, border-color .12s ease;
        }

        .menu-link:hover {
            border-color: #94a3b8;
            background: #f1f7ff;
            text-decoration: none;
        }
    </style>

