<zk>
	<label multiline="true">
		1. Click "Set Preferred Locale (fr-CA)" and check the html lang is "fr-CA".
		2. Click "Set Preferred Locale + Open Root Lang Page" and check the html lang is "en".

		Expected result:
		- Preferred locale is used when root-attributes lang is not specified.
		- root-attributes lang has higher priority when specified.
	</label>
	<button id="setFrLocale" label="Set Preferred Locale (fr-CA)">
		<attribute name="onClick"><![CDATA[
			java.util.Locale locale = org.zkoss.util.Locales.getLocale("fr_CA");
			session.setAttribute(org.zkoss.web.Attributes.PREFERRED_LOCALE, locale);
			execution.sendRedirect("F104-ZK-6059.zul");
		]]></attribute>
	</button>
	<button id="setFrLocaleAndGotoRootLang" label="Set Preferred Locale + Open Root Lang Page">
		<attribute name="onClick"><![CDATA[
			java.util.Locale locale = org.zkoss.util.Locales.getLocale("fr_CA");
			session.setAttribute(org.zkoss.web.Attributes.PREFERRED_LOCALE, locale);
			execution.sendRedirect("F104-ZK-6059-2.zul");
		]]></attribute>
	</button>
</zk>
