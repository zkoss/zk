<zk>
    <zscript><![CDATA[
        import org.zkoss.zul.*;
        import org.zkoss.zk.ui.ext.*;
        import java.util.*;

        ListModelList contribs = new ListModelList();
        Object[][] DATA = {
            {1, "Arabic",   "Ayman",    "iso-8859-6"},
            {2, "Chinese",  "Tom Yeh",  "UTF-8"},
            {3, "French",   "Jean",     "UTF-8"},
            {4, "German",   "Hans",     "UTF-8"},
            {5, "Japanese", "Taro",     "UTF-8"},
            {6, "Spanish",  "Carlos",   "UTF-8"}
        };
        for (int i = 0; i < DATA.length; i++) contribs.add(DATA[i]);

        RowRenderer myRenderer = new RowRenderer() {
            public void render(Row row, Object data, int index) {
                Object[] c = (Object[]) data;
                row.appendChild(new Label(String.valueOf(c[0])));
                row.appendChild(new Label((String) c[1]));
                row.appendChild(new Label((String) c[2]));
                row.appendChild(new Label((String) c[3]));
                Button b = new Button("Like");
                row.appendChild(b);
            }
        };
    ]]></zscript>

    <grid id="grid1" responsive="stacking"
          width="100%" height="400px"
          model="${contribs}" rowRenderer="${myRenderer}">
        <auxhead>
            <auxheader label="Contributor of ZK International Message" colspan="5" />
        </auxhead>
        <columns>
            <column label="Id"          width="60px"  align="right" />
            <column label="Language"    width="120px" />
            <column label="Contributor" />
            <column label="Charset"     width="100px" responsiveVisible="false" />
            <column label="Like"        width="90px" />
        </columns>
    </grid>
</zk>
