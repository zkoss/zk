<?xml version="1.0" encoding="UTF-8" ?>
<zk>
    <!-- for F104-ZK-5997: CSP strict-dynamic with nonce on all scripts -->
    <listener>
        <listener-class>org.zkoss.zkmax.au.websocket.WebSocketWebAppInit</listener-class>
    </listener>
    <language-addon>
        <javascript>
            window.zkLangAddonLoaded = true;
        </javascript>
    </language-addon>
    <device-config>
        <device-type>ajax</device-type>
        <embed>
            <![CDATA[
				<script type="text/javascript">
					window.zkEmbedScriptLoaded = true;
				</script>
            ]]>
        </embed>
    </device-config>
    <system-config>
        <csp-enabled>true</csp-enabled>
        <csp-strict-dynamic-enabled>true</csp-strict-dynamic-enabled>
    </system-config>
</zk>
