<zk>
	<label multiline="true">
		Test: Searchbox clear icon should appear inside the input field in iceblue_c theme.

		Steps to reproduce:
		1. Open this page with iceblue_c theme
		2. Select any item from the searchbox
		3. Observe the clear (x) icon position

		Expected: The clear icon (x) appears inside the searchbox input field.
		Bug: The clear icon appears outside (to the right of) the searchbox.
	</label>
	<zscript><![CDATA[
		import org.zkoss.zul.ListModelArray;
		ListModel model = new ListModelArray(new String[] {
			"North America", "South America", "Europe", "Asia", "Africa", "Oceania", "Antarctica"
		});
	]]></zscript>
	<searchbox id="sb" model="${model}" placeholder="An unknown place" autoclose="true">
		<template name="model">
			<html><![CDATA[
		<i class="z-icon-globe"></i> ${each}
		]]></html>
		</template>
	</searchbox>
</zk>
