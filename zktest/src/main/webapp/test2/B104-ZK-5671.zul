<div>
    <zscript>
        import org.zkoss.util.media.AMedia;
        public AMedia loadPdf() {
            return new AMedia(application.getResource(execution.toAbsoluteURI("B1896797.pdf", true)), null, null);
        }
        AMedia document = loadPdf();
    </zscript>
    <label multiline="true">
        On a HiDPI monitor (or with devicePixelRatio &gt; 1) the rendered PDF page
        should stay sharp, not blurry. The canvas backing-store width/height should
        be multiplied by window.devicePixelRatio, while the canvas CSS size should
        match the viewport size.
    </label>
    <pdfviewer id="pdf" content="${document}"/>
</div>
