<zk>
    <label multiline="true">
        Reproduce JS error when using a datebox inside a closed groupbox that
		is itself inside a groupbox toggled visible/title via MVVM.
        1. click first groupbox to open
        2. click second groupbox to open
    </label>
	<script><![CDATA[
		window.__jsErrors = [];
		window.addEventListener('error', function (e) {
			window.__jsErrors.push(String(e.message || e.error));
		});
	]]></script>
	<div apply="org.zkoss.bind.BindComposer" viewModel="@id('vm') @init('org.zkoss.zktest.test2.B104_ZK_6071_VM')">
		<button id="view" label="view" height="29px" onClick="@command('doCmd')"/>
		<groupbox id="outer" title="@load(vm.no)" visible="@load(vm.visible)" vflex="1">
			<vbox vflex="1">
				<groupbox id="inner" open="false" title="init close">
					<datebox id="db" value="@load(vm.date)"/>
				</groupbox>
			</vbox>
		</groupbox>
	</div>
</zk>
