<zk>
    <div style="padding: 10px;">
        <grid id="grid1" responsive="none" width="100%">
            <columns>
                <column label="Name" />
                <column label="Email" />
                <column label="Department" />
            </columns>
            <rows>
                <row>
                    <label value="John" />
                    <label value="john@example.com" />
                    <label value="Engineering" />
                </row>
                <row>
                    <label value="Jane" />
                    <label value="jane@example.com" />
                    <label value="Design" />
                </row>
            </rows>
        </grid>
    </div>
</zk>