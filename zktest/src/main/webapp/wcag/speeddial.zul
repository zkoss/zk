<?xml version="1.0" encoding="UTF-8"?>
<?page title="WCAG: Speeddial"?>
<?root-attributes lang="en"?>
<?xml version="1.0" encoding="UTF-8"?>
<!--
speeddial.zul

        Purpose:

        Description:

        History:
